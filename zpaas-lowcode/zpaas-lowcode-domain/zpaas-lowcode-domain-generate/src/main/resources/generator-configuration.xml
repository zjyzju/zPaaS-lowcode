        </commentGenerator>

        <!-- 链接数据库的配置  MySQL8之前的驱动com.mysql.jdbc.Driver，新的驱动com.mysql.cj.jdbc.Driver，并且要加时区-->
        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://[fd15:4ba5:5a2b:1009::10]:3306/zpaas_lowcode_revise?useUnicode=true&amp;characterEncoding=utf-8&amp;tinyInt1isBit=true&amp;allowMultiQueries=true"
